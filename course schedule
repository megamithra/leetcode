class Solution:
    def canFinish(self, numCourses, prerequisites):
        graph = {i:[] for i in range(numCourses)}
        for a,b in prerequisites:
            graph[a].append(b)
        visit = set()
        path = set()
        def dfs(course):
            if course in path:
                return False
            if course in visit:
                return True
            path.add(course)
            for nei in graph[course]:
                if not dfs(nei):
                    return False
            path.remove(course)
            visit.add(course)
            return True
        for c in range(numCourses):
            if not dfs(c):
                return False
        return True
        
